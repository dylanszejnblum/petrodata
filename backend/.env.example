# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Port the NestJS server listens on
PORT=3001

# Absolute path to the directory containing CSV data files
CSV_DATA_DIR="/absolute/path/to/data/data-v1"

# US Energy Information Administration API key
# Get one at https://www.eia.gov/opendata/register.php
EIA_API_KEY="your-eia-api-key"
